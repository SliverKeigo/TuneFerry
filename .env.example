# ============================================================
# Apple Music Library Organizer - Environment Variables Example
# Copy this file to `.env` at the repo root.
# The same file powers `vercel dev` locally and is mirrored to Vercel
# project env vars for production.
# Never commit `.env` or any .p8 private-key file.
# ============================================================

# ---------- Apple Music Developer Token ----------
# MVP mode: paste a pre-generated Developer Token here. The /api function
# returns it verbatim and never touches the signing path.
# Leave empty to force the server to sign its own JWT.
APPLE_MUSIC_DEVELOPER_TOKEN=

# Production signing mode. Required Apple Developer account assets:
#   1. Media Services Key (Apple Music). Download the .p8 private-key file.
#   2. Your Apple Developer Team ID.
#   3. The Key ID of the Media Services Key.
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Inline PEM content. **Required on Vercel** — serverless functions have no
# persistent filesystem, so APPLE_PRIVATE_KEY_PATH is local-only.
# If APPLE_PRIVATE_KEY is set it takes precedence over APPLE_PRIVATE_KEY_PATH.
APPLE_PRIVATE_KEY=

# Local-only alternative: path to the downloaded .p8 file. Ignored on Vercel.
APPLE_PRIVATE_KEY_PATH=

# JWT lifetime in seconds. Apple allows up to 15777000 (~6 months).
APPLE_TOKEN_TTL_SECONDS=15777000

# ---------- Client (Vite reads these at build time) ----------
# Default points at `vercel dev` (port 3000). Override to target a preview URL.
VITE_API_BASE_URL=http://localhost:3000
VITE_DEFAULT_STOREFRONT=us
