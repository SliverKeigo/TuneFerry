# ============================================================
# Apple Music Library Organizer - Environment Variables Example
# Copy this file to `.env` at the repo root before running the server.
# Never commit `.env` or any .p8 private-key file.
# ============================================================

# ---------- Server ----------
PORT=8787
NODE_ENV=development

# Allowed origin for the Vite dev server.
# Use a comma-separated list for multiple origins.
CLIENT_ORIGIN=http://localhost:5173

# ---------- Apple Music Developer Token ----------
# MVP mode: paste a pre-generated Developer Token here and the server
# will serve it directly without signing its own JWT.
# Leave empty to force the server to sign its own token using the values below.
APPLE_MUSIC_DEVELOPER_TOKEN=

# Production mode: the server signs its own Developer Token (JWT, ES256).
# Required Apple Developer account assets:
#   1. Media Services Key (Apple Music). Download the .p8 private-key file.
#   2. Your Apple Developer Team ID.
#   3. The Key ID of the Media Services Key.
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Absolute path to the .p8 file, OR paste the full PEM content inline.
# If both are provided, APPLE_PRIVATE_KEY takes precedence.
APPLE_PRIVATE_KEY_PATH=
APPLE_PRIVATE_KEY=

# Token lifetime in seconds. Apple allows up to 15777000 (~6 months).
APPLE_TOKEN_TTL_SECONDS=15777000

# ---------- Client ----------
# The Vite client reads these at build time (must be prefixed with VITE_).
# They can live in /client/.env as well, but we centralise them here for MVP.
VITE_API_BASE_URL=http://localhost:8787
VITE_DEFAULT_STOREFRONT=us
