# ============================================================
# TuneFerry — Environment Variables Example
# Copy this file to `.env` at the repo root.
# Next.js auto-loads .env when running `next dev` / `next build`.
# Never commit `.env` or any `.p8` private-key file.
#
# Spotify: NO env vars needed. Public playlists are read by scraping the
# public embed page (https://open.spotify.com/embed/playlist/<id>) — no
# OAuth, no API key, no Premium subscription.
# ============================================================

# ---------- Apple Music Developer Token ----------
# Paste a pre-generated Developer Token here. The catalog search APIs
# return it verbatim and never touch the signing path.
# - WebPlay-scraped tokens (free): scrape from https://beta.music.apple.com
# - Self-signed (Apple Developer Program): use the keys below
APPLE_MUSIC_DEVELOPER_TOKEN=

# Optional self-sign mode. Requires an Apple Developer Program subscription.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_PRIVATE_KEY_PATH=
APPLE_TOKEN_TTL_SECONDS=15777000

# ---------- Client (Next.js — prefix NEXT_PUBLIC_ to expose to browser) ----------
# Initial Apple Music storefront the app boots with (e.g. us, jp, hk, tw, gb).
NEXT_PUBLIC_DEFAULT_STOREFRONT=us
