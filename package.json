{
  "name": "tuneferry",
  "version": "0.1.0",
  "private": true,
  "description": "TuneFerry — migrate Spotify playlists to Apple Music. Match by ISRC + artist/title fuzzy, export deep links and .m3u8.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate": "npm-run-all --parallel check typecheck test",
    "clean": "rimraf .next coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "npm@10.8.2"
}
